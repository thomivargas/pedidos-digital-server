# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:5432/database"
# ─── SERVIDOR ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── JWT (generar con: openssl rand -hex 32) ─────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── BCRYPT ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── CORS (URL del frontend, sin slash al final) ─────────────────────────────
CORS_ORIGIN=https://tu-dominio-frontend.vercel.app

# ─── GOOGLE FORMS (opcionales — si no se configuran, el envío se omite) ─────
GOOGLE_FORM_URL=
GOOGLE_FORM_ENTRY_PEDIDO=
GOOGLE_FORM_ENTRY_PRODUCTO=
GOOGLE_FORM_ENTRY_SKU=
GOOGLE_FORM_ENTRY_PRECIO=
GOOGLE_FORM_ENTRY_COTIZACION=
GOOGLE_FORM_ENTRY_VENDEDOR=
